# ─────────────────────────────────────────────────────────────────────────────
# .env Template — LJMU Thesis RAG Pipeline
#
# Setup instructions:
#   1. Copy this file to a new file named `.env` in the project root
#   2. Replace the placeholder values below with your actual API keys and path
#   3. NEVER commit `.env` to GitHub — it is excluded in `.gitignore`
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini API Key
# Used by:
#   - Knowledge Base generation (gemini-3-flash-preview)
#   - Golden Dataset generation (gemini-2.5-flash)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key
# Used by:
#   - RAG generation (llama-3.3-70b-versatile)
#   - RAGAS evaluation judge (llama-3.3-70b-versatile)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Path Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Absolute path to the project root directory.
# Use forward slashes (/) even on Windows — pathlib handles them correctly
# and avoids backslash escaping issues.
#
# Examples:
#   Windows: BASE_PATH=E:/UpGrad/LJMU_Thesis/Topic_1_Energy_Forecasting/Research_Proposal/Code
#   Mac:     BASE_PATH=/Users/zoheb/Documents/RAG-Based-Energy-Forecasting
#   Linux:   BASE_PATH=/home/zoheb/projects/RAG-Based-Energy-Forecasting

BASE_PATH=/absolute/path/to/this/repo
